# ─── Noda Frontend — .env ────────────────────────────────────
# คัดลอกไฟล์นี้เป็น .env แล้วกรอกค่าที่ได้จาก Google Form

# URL ของ Noda Backend (Railway) — ไม่ต้องเปลี่ยน
VITE_API_URL=https://noda-backend-production.up.railway.app

# ID ของชุมชนคุณ — ได้จากอีเมลหลังกรอก Google Form
VITE_COMMUNITY_ID=your-community-id

# ชื่อชุมชน (แสดงบนหน้า login) — ไม่บังคับ
VITE_COMMUNITY_NAME=ชื่อชุมชนของคุณ

# ─── Dev only ─────────────────────────────────────────────────
# ข้าม auth ตอน dev (true = ข้าม, false = ปกติ)
VITE_SKIP_AUTH=false
